# =============================================================================
# Weatherbot environment variables
# Copy this file to .env and fill in what you need.
# .env is gitignored, never commit it.
# =============================================================================


# -----------------------------------------------------------------------------
# Visual Crossing API key (optional, for sigma calibration)
# -----------------------------------------------------------------------------
# Used by bot_v2 to fetch actual resolved daily-max temps after markets close.
# This lets the bot learn how accurate each forecast source is per city.
# Free tier: 1000 calls/day. Way more than you need.
# Get one at https://www.visualcrossing.com/weather-api
# Bot works fine without this. Calibration just won't run.

VC_KEY=


# -----------------------------------------------------------------------------
# Polymarket live trading (only set these when you're ready for real money)
# -----------------------------------------------------------------------------
# DO NOT FILL THESE UNTIL YOU HAVE:
#   1. Run paper trading for at least 2 weeks
#   2. Resolved 50+ markets with positive PnL
#   3. Read the live trading section in README.md
#
# These keys give a script the ability to spend USDC from your wallet.
# Treat POLY_PRIVATE_KEY like your bank password.

# Master safety switch. Bot REFUSES to place real orders unless this is "true".
# Default false means even if everything else is set, nothing real happens.
LIVE_TRADING=false

# Your Polymarket account's private key.
# In Polymarket, go to settings -> Reveal Key (Magic wallet)
# Or export from your MetaMask if you use one.
# Format: 0x followed by 64 hex chars
POLY_PRIVATE_KEY=

# Your Polymarket profile address (the address that holds your USDC).
# Find it in your Polymarket profile / deposit page.
# Format: 0x followed by 40 hex chars
POLY_FUNDER_ADDRESS=

# Wallet signature type:
#   0 = EOA (MetaMask, Ledger, hardware wallets)
#   1 = Magic/email wallet (default for Polymarket email signup)
#   2 = Gnosis Safe / smart contract wallet
POLY_SIGNATURE_TYPE=1
